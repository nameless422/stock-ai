REMOTE_HOST=your.server.ip
REMOTE_USER=ubuntu
REMOTE_PORT=22
REMOTE_APP_DIR=/home/ubuntu/stock-ai
APP_USER=ubuntu

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=stock_ai
MYSQL_APP_USER=stock_ai
MYSQL_APP_PASSWORD=your_strong_password

STOCK_AI_DB_URL=mysql://stock_ai:your_strong_password@127.0.0.1:3306/stock_ai?charset=utf8mb4

MINIMAX_API_KEY=your_minimax_api_key

# Optional
# REMOTE_PASSWORD=your_server_password
# MYSQL_ROOT_PASSWORD=your_mysql_root_password
# OPENAI_API_KEY=your_openai_api_key
